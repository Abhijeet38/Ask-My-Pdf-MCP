# ============================================================================
# pdf-qa-mcp configuration. Copy to `.env` and adjust.
# ============================================================================

# ---- LLM provider ----------------------------------------------------------
# Primary provider:   bedrock | ollama
# Optional fallback:  set LLM_FALLBACK=ollama to auto-retry on Bedrock failures
#                     (AWS creds expired, throttling, network errors, etc.)
LLM_PROVIDER=bedrock
LLM_FALLBACK=ollama

# ---- Bedrock (primary) -----------------------------------------------------
# Uses your local AWS credentials chain (env vars, ~/.aws/credentials, IAM role).
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
# Other current options:
#   us.anthropic.claude-sonnet-4-5-20250929-v1:0  (sharper, slower, $$)
#   anthropic.claude-haiku-4-5-20251001-v1:0      (no inference profile prefix)

# ---- Ollama (fallback / fully local) ---------------------------------------
# Requires `brew services start ollama` and `ollama pull <model>`.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
# Larger options:
#   llama3.1:8b   (4.7 GB, sharper)
#   qwen2.5:7b    (4.7 GB, strong on factual)
#   mistral:7b    (4.1 GB, fast)

# ---- OpenSearch ------------------------------------------------------------
# Default: local Docker / tarball with security plugin disabled.
OS_HOST=localhost
OS_PORT=9200
OS_USE_SSL=false
OS_USE_AWS_AUTH=false
OS_INDEX=pdf_qa_chunks
OS_PAGES_INDEX=pdf_qa_pages

# Local with basic auth — set OS_USER + OS_PASSWORD instead.
# OS_USER=admin
# OS_PASSWORD=admin

# AWS-managed OpenSearch (SigV4 via boto3 default credential chain)
# OS_HOST=search-...amazonaws.com
# OS_PORT=443
# OS_USE_SSL=true
# OS_USE_AWS_AUTH=true

# ---- Embedding model -------------------------------------------------------
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
# Auto-detects mps (Apple Silicon) > cuda > cpu when set to "auto"
EMBEDDING_DEVICE=auto

# ---- Ingestion -------------------------------------------------------------
DATA_DIR=./data
CHUNK_TOKENS=400
CHUNK_OVERLAP=60
TOP_K=5
